{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "edit": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "grep": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "*.env*": "deny"
    }
  }
}
